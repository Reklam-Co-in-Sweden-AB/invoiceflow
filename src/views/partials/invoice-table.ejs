<%
function formatSEK(n) { return Math.round(n).toLocaleString('sv-SE') + ' kr'; }
function serviceLabel(s) {
  return s === 'marknadskoordinator' ? 'Marknadskoord.' : s === 'supportavtal' ? 'Supportavtal' : 'Webbhotell';
}
%>

<% invoices.forEach(inv => { %>
  <tr class="hover:bg-gray-50/60 transition-colors border-b border-gray-50" x-data="{ open: false }">
    <td class="text-center"><input type="checkbox" name="ids" value="<%= inv.id %>" class="w-3.5 h-3.5 rounded border-gray-300 cursor-pointer"></td>
    <td class="font-medium text-gray-900"><%= inv.customer.name %></td>
    <td class="text-gray-500 text-xs"><%= serviceLabel(inv.serviceType) %></td>
    <td class="text-right font-semibold num"><%= formatSEK(inv.totalAmount) %></td>
    <td class="text-center text-xs text-gray-400"><%= inv.lines.length %></td>
    <td><span class="pill pill-pending">Väntar</span></td>
    <td>
      <button x-on:click="open = !open" class="text-gray-400 hover:text-gray-600">
        <svg class="w-4 h-4 transition-transform" x-bind:class="open && 'rotate-180'" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
      </button>
    </td>
  </tr>
  <tr x-show="open" x-collapse class="bg-gray-50/50">
    <td></td>
    <td colspan="6" class="py-3">
      <div class="bg-white rounded-lg border border-gray-100 p-3 space-y-2">
        <% inv.lines.forEach(line => { %>
          <div class="flex items-center justify-between text-xs">
            <div>
              <% if (line.article) { %>
                <span class="text-gray-400 font-mono">Art.<%= line.article.articleNumber %></span>
              <% } %>
              <span class="text-gray-700 font-medium ml-1"><%= line.text %></span>
            </div>
            <div class="num text-gray-500"><%= line.quantity %> st × <%= formatSEK(line.unitPrice) %></div>
          </div>
        <% }) %>
      </div>
    </td>
  </tr>
<% }) %>

<% if (invoices.length === 0) { %>
  <tr><td colspan="7" class="text-center text-gray-400 py-8">Inga fakturor matchar filtren.</td></tr>
<% } %>
