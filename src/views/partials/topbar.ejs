<header class="topbar px-6 py-3 flex items-center justify-between">
  <div>
    <% if (typeof pageTitle !== 'undefined') { %>
      <h1 class="text-base font-bold text-gray-900"><%= pageTitle %></h1>
    <% } %>
  </div>
  <div class="flex items-center gap-3">
    <span class="text-[13px] text-gray-500"><%= user.name %></span>
    <form action="/logout" method="POST" class="inline">
      <button type="submit" class="text-[12px] text-gray-400 hover:text-gray-600">Logga ut</button>
    </form>
  </div>
</header>
