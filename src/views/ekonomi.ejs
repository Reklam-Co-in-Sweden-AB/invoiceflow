            </tr>
            <!-- Råvaror (editable) -->
            <tr class="border-b border-gray-50 text-gray-600">
              <td class="text-left sticky left-0 bg-white z-10">Råvaror</td>
              <% for (let i = 0; i < 12; i++) { %>
                <td class="num p-0">
                  <input type="text" inputmode="decimal"
                    class="w-full text-right bg-transparent px-2 py-1.5 text-[13px] focus:bg-teal-50 focus:outline-none rounded"
                    :value="formatTkr(data[<%= i %>].ravaror)"
                    @focus="$el.select()"
                    @blur="saveCell(<%= i %>, 'ravaror', $el.value)"
                    @keydown.enter="$el.blur()">
                </td>
              <% } %>
              <td class="num bg-gray-50" x-text="formatTkr(totals.ravaror)"></td>
            </tr>
            <!-- Bruttovinst (computed) -->
            <tr class="border-b border-gray-200 font-semibold bg-blue-50/30">
              <td class="text-left sticky left-0 bg-blue-50/30 z-10">Bruttovinst</td>
              <% for (let i = 0; i < 12; i++) { %>
                <td class="num" :class="negCls(data[<%= i %>].intakter - data[<%= i %>].ravaror)" x-text="formatTkr(data[<%= i %>].intakter - data[<%= i %>].ravaror)"></td>
              <% } %>
              <td class="num bg-gray-50 font-bold" :class="negCls(totals.bruttovinst)" x-text="formatTkr(totals.bruttovinst)"></td>
            </tr>
            <!-- Övriga externa kostnader (editable) -->
            <tr class="border-b border-gray-50 text-gray-600">
              <td class="text-left sticky left-0 bg-white z-10">Övriga externa kostnader</td>
              <% for (let i = 0; i < 12; i++) { %>
                <td class="num p-0">
                  <input type="text" inputmode="decimal"
                    class="w-full text-right bg-transparent px-2 py-1.5 text-[13px] focus:bg-teal-50 focus:outline-none rounded"
                    :value="formatTkr(data[<%= i %>].ovriga_kostnader)"
                    @focus="$el.select()"
                    @blur="saveCell(<%= i %>, 'ovriga_kostnader', $el.value)"
                    @keydown.enter="$el.blur()">
                </td>
              <% } %>
              <td class="num bg-gray-50" x-text="formatTkr(totals.ovriga_kostnader)"></td>
            </tr>
            <tr class="border-b border-gray-50 text-gray-400 text-[11px]">
              <td class="text-left sticky left-0 bg-white z-10 pl-6">% av intäkter</td>
              <% for (let i = 0; i < 12; i++) { %>
                <td class="num" x-text="formatPct(data[<%= i %>].intakter ? data[<%= i %>].ovriga_kostnader / data[<%= i %>].intakter * 100 : 0)"></td>
              <% } %>
              <td class="num bg-gray-50" x-text="formatPct(totals.intakter ? totals.ovriga_kostnader / totals.intakter * 100 : 0)"></td>
            </tr>
            <!-- Personalkostnader (editable) -->
            <tr class="border-b border-gray-50 text-gray-600">
              <td class="text-left sticky left-0 bg-white z-10">Personalkostnader</td>
              <% for (let i = 0; i < 12; i++) { %>
                <td class="num p-0">
                  <input type="text" inputmode="decimal"
                    class="w-full text-right bg-transparent px-2 py-1.5 text-[13px] focus:bg-teal-50 focus:outline-none rounded"
                    :value="formatTkr(data[<%= i %>].personalkostnad)"
                    @focus="$el.select()"
                    @blur="saveCell(<%= i %>, 'personalkostnad', $el.value)"
                    @keydown.enter="$el.blur()">
                </td>
              <% } %>
              <td class="num bg-gray-50" x-text="formatTkr(totals.personalkostnad)"></td>
            </tr>
            <tr class="border-b border-gray-50 text-gray-400 text-[11px]">
              <td class="text-left sticky left-0 bg-white z-10 pl-6">% av intäkter</td>
              <% for (let i = 0; i < 12; i++) { %>
                <td class="num" x-text="formatPct(data[<%= i %>].intakter ? data[<%= i %>].personalkostnad / data[<%= i %>].intakter * 100 : 0)"></td>
              <% } %>
              <td class="num bg-gray-50" x-text="formatPct(totals.intakter ? totals.personalkostnad / totals.intakter * 100 : 0)"></td>
            </tr>
            <!-- Rörelseresultat (computed) -->
            <tr class="border-b border-gray-200 font-semibold bg-green-50/30">
              <td class="text-left sticky left-0 bg-green-50/30 z-10">Rörelseresultat</td>
              <% for (let i = 0; i < 12; i++) { %>
                <td class="num" :class="negCls(rorelseresultat(<%= i %>))" x-text="formatTkr(rorelseresultat(<%= i %>))"></td>
              <% } %>
              <td class="num bg-gray-50 font-bold" :class="negCls(totals.rorelseresultat)" x-text="formatTkr(totals.rorelseresultat)"></td>
            </tr>
            <tr class="border-b border-gray-50 text-gray-400 text-[11px]">
              <td class="text-left sticky left-0 bg-white z-10 pl-6">% av intäkter</td>
              <% for (let i = 0; i < 12; i++) { %>
                <td class="num" x-text="formatPct(data[<%= i %>].intakter ? rorelseresultat(<%= i %>) / data[<%= i %>].intakter * 100 : 0)"></td>
              <% } %>
              <td class="num bg-gray-50" x-text="formatPct(totals.intakter ? totals.rorelseresultat / totals.intakter * 100 : 0)"></td>
            </tr>
            <!-- Finansiella poster (editable) -->
            <tr class="border-b border-gray-50 text-gray-600">
              <td class="text-left sticky left-0 bg-white z-10">Finansiella poster</td>
              <% for (let i = 0; i < 12; i++) { %>
                <td class="num p-0">
                  <input type="text" inputmode="decimal"
                    class="w-full text-right bg-transparent px-2 py-1.5 text-[13px] focus:bg-teal-50 focus:outline-none rounded"
                    :value="formatTkr(data[<%= i %>].finansiella)"
                    @focus="$el.select()"
                    @blur="saveCell(<%= i %>, 'finansiella', $el.value)"
                    @keydown.enter="$el.blur()">
                </td>
              <% } %>
              <td class="num bg-gray-50" x-text="formatTkr(totals.finansiella)"></td>
            </tr>
            <!-- Resultat (computed) -->
            <tr class="border-b border-gray-200 font-bold bg-amber-50/30">
              <td class="text-left sticky left-0 bg-amber-50/30 z-10">Resultat</td>
              <% for (let i = 0; i < 12; i++) { %>
                <td class="num" :class="negCls(resultat(<%= i %>))" x-text="formatTkr(resultat(<%= i %>))"></td>
              <% } %>
              <td class="num bg-gray-50 font-bold" :class="negCls(totals.resultat)" x-text="formatTkr(totals.resultat)"></td>
            </tr>
            <tr class="text-gray-400 text-[11px]">
              <td class="text-left sticky left-0 bg-white z-10 pl-6">% av intäkter</td>
              <% for (let i = 0; i < 12; i++) { %>
                <td class="num" x-text="formatPct(data[<%= i %>].intakter ? resultat(<%= i %>) / data[<%= i %>].intakter * 100 : 0)"></td>
              <% } %>
              <td class="num bg-gray-50" x-text="formatPct(totals.intakter ? totals.resultat / totals.intakter * 100 : 0)"></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div><!-- end prognos tab -->

  <!-- ANALYS Tab: Card-based monthly view -->
  <div x-show="tab === 'analys'" x-cloak x-data="analysisCards()">
    <div class="space-y-3">
      <div class="px-1 mb-2">
        <p class="text-xs text-gray-400">Varje månad jämförs med föregående. Gul markering = avvikelse &gt;20% eller &gt;50 tkr.</p>
      </div>

      <template x-for="m in monthsWithData" :key="m">
        <div class="card overflow-hidden">
          <!-- Card header: clickable -->
          <button class="w-full px-5 py-3 flex items-center justify-between text-left hover:bg-gray-50/50 transition-colors"
            @click="toggleMonth(m)">
            <div class="flex items-center gap-3">
              <svg class="w-4 h-4 text-gray-400 transition-transform" :class="expandedMonth === m ? 'rotate-90' : ''" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
              <div>
                <h3 class="text-sm font-bold text-gray-900" x-text="monthTitle(m)"></h3>
                <span class="text-xs text-gray-400" x-text="compLabel(m)"></span>
              </div>
            </div>
            <div class="flex items-center gap-4 text-right">
              <div class="text-xs text-gray-500">
                <span>Resultat </span>
                <span class="font-bold text-sm" :class="resultatCls(m)" x-text="fmtTkr(val(m, 'resultat')) + ' tkr'"></span>
              </div>
              <div class="text-xs">
                <span :class="resultDiffCls(m, 'resultat')" x-text="fmtDiff(diff(m, 'resultat')) + ' tkr ' + fmtPct(m, 'resultat')"></span>
              </div>
            </div>
          </button>

          <!-- Expanded content -->
          <template x-if="expandedMonth === m">
            <div class="border-t border-gray-100">
              <!-- P&L Summary -->
              <div class="px-5 py-4">
                <div class="space-y-0">
                  <template x-for="f in plFields" :key="f.key">
                    <div>
                      <!-- Separator line before computed rows -->
                      <template x-if="f.sep">
                        <div class="border-t border-gray-200 my-1"></div>
                      </template>
                      <div class="flex items-baseline justify-between py-1" :class="f.computed ? 'font-semibold' : ''">
                        <span class="text-sm text-gray-700 w-36 shrink-0" x-text="f.label"></span>
                        <div class="flex items-baseline gap-4 text-right">
                          <span class="text-sm text-gray-900 w-20 text-right" x-text="fmtTkr(val(m, f.key)) + ' tkr'"></span>
                          <span class="text-xs w-32 text-right" :class="f.computed ? resultDiffCls(m, f.key) : diffCls(m, f.key, f)">
                            <span x-text="fmtDiff(diff(m, f.key)) + ' tkr'"></span>
                            <span class="text-gray-400 ml-0.5" x-text="fmtPct(m, f.key)"></span>
                          </span>
                        </div>
                      </div>
                    </div>
                  </template>
                </div>
              </div>

              <!-- Account-level changes -->
              <template x-if="hasAccountDiffs(m)">
                <div class="border-t border-gray-100">
                  <button class="w-full px-5 py-2.5 flex items-center gap-2 text-left hover:bg-gray-50/50 transition-colors"
                    @click="toggleAccounts(m)">
                    <svg class="w-3 h-3 text-gray-400 transition-transform" :class="showAccounts[m] ? 'rotate-90' : ''" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                    <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Kontoförändringar</span>
                    <span class="text-xs text-gray-400" x-text="compLabel(m)"></span>
                  </button>
                  <template x-if="showAccounts[m]">
                    <div class="px-5 pb-4 space-y-3">
                      <template x-for="group in accountDiffs(m)" :key="group.label">
                        <div>
                          <div class="text-[11px] font-semibold text-gray-400 uppercase tracking-wide mb-1" x-text="group.label"></div>
                          <div class="divide-y divide-gray-100 border border-gray-200 rounded-lg overflow-hidden">
                            <template x-for="acct in group.accounts" :key="acct.account">
                              <div class="px-3 py-2.5 hover:bg-gray-50/50">
                                <div class="flex items-baseline justify-between gap-3">
                                  <div class="flex items-baseline gap-2 min-w-0">
                                    <span class="font-mono text-xs text-gray-400 w-12 shrink-0" x-text="acct.account"></span>
                                    <span class="text-xs text-gray-600 truncate" x-text="acct.name" x-show="acct.name"></span>
                                  </div>
                                  <span class="text-xs font-semibold shrink-0" :class="acctDiffCls(acct.diff)" x-text="(acct.diff >= 0 ? '+' : '') + Math.round(acct.diff / 1000).toLocaleString('sv-SE') + ' tkr'"></span>
                                </div>
                                <template x-if="(acct.vouchers || []).length > 0">
                                  <div class="mt-1.5 space-y-0.5">
                                    <template x-for="(v, vi) in (acct.vouchers || [])" :key="vi">
                                      <div class="flex items-baseline justify-between gap-2 text-xs leading-snug">
                                        <span class="transition-colors"
                                          :class="parseVoucherRef(vText(v)) ? 'text-blue-600 hover:text-blue-800 hover:underline cursor-pointer' : 'text-gray-500 select-all'"
                                          @click="parseVoucherRef(vText(v)) && openVoucher(vText(v))"
                                          x-text="vText(v)"></span>
                                        <span class="text-gray-400 shrink-0 tabular-nums" x-show="vAmt(v)" x-text="fmtTkr(vAmt(v)) + ' tkr'"></span>
                                      </div>
                                    </template>
                                  </div>
                                </template>
                              </div>
                            </template>
                          </div>
                        </div>
                      </template>
                    </div>
                  </template>
                </div>
              </template>
            </div>
          </template>
        </div>
      </template>

      <!-- Empty state -->
      <template x-if="monthsWithData.length === 0">
        <div class="card px-5 py-8 text-center text-gray-400 text-sm">
          Ingen data att analysera ännu.
        </div>
      </template>
    </div>

    <!-- Invoice detail modal -->
    <template x-if="invoiceModal || invoiceLoading">
      <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/30" @click.self="closeModal()" @keydown.escape.window="closeModal()">
        <div class="bg-white rounded-xl shadow-xl max-w-lg w-full mx-4 max-h-[80vh] overflow-y-auto">
          <!-- Loading -->
          <template x-if="invoiceLoading && !invoiceModal">
            <div class="p-8 text-center text-gray-400">
              <svg class="animate-spin h-6 w-6 mx-auto mb-2 text-gray-400" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
              Hämtar faktura...
            </div>
          </template>
          <!-- Error -->
          <template x-if="invoiceModal && invoiceModal.error">
            <div class="p-6">
              <div class="flex items-center justify-between mb-3">
                <h3 class="font-bold text-gray-900">Faktura</h3>
                <button @click="closeModal()" class="text-gray-400 hover:text-gray-600">&times;</button>
              </div>
              <p class="text-sm text-red-600" x-text="invoiceModal.error"></p>
            </div>
          </template>
          <!-- Invoice detail -->
          <template x-if="invoiceModal && !invoiceModal.error">
            <div class="p-6">
              <div class="flex items-center justify-between mb-4">
                <div>
                  <h3 class="font-bold text-gray-900">
                    <span x-text="invoiceModal.type === 'supplier' ? 'Leverantörsfaktura' : 'Kundfaktura'"></span>
                    <span class="text-gray-400 font-normal" x-text="'#' + invoiceModal.number"></span>
                  </h3>
                  <p class="text-sm text-gray-500" x-text="invoiceModal.customerName || invoiceModal.supplierName || ''"></p>
                </div>
                <button @click="closeModal()" class="text-gray-400 hover:text-gray-600 text-xl leading-none">&times;</button>
              </div>
              <div class="grid grid-cols-2 gap-3 text-sm mb-4">
                <div>
                  <span class="text-gray-400 text-xs">Datum</span>
                  <div class="font-medium" x-text="fmtDate(invoiceModal.date)"></div>
                </div>
                <div>
                  <span class="text-gray-400 text-xs">Förfallodatum</span>
                  <div class="font-medium" x-text="fmtDate(invoiceModal.dueDate)"></div>
                </div>
                <div>
                  <span class="text-gray-400 text-xs">Belopp</span>
                  <div class="font-bold" x-text="fmtSEK(invoiceModal.totalAmount)"></div>
                </div>
                <div>
                  <span class="text-gray-400 text-xs">Status</span>
                  <div class="font-medium">
                    <template x-if="invoiceModal.type === 'customer'">
                      <span :class="invoiceModal.isPaid ? 'text-emerald-600' : 'text-amber-600'" x-text="invoiceModal.isPaid ? 'Betald' : 'Obetald'"></span>
                    </template>
                    <template x-if="invoiceModal.type === 'supplier'">
                      <span x-text="invoiceModal.status || '–'"></span>
                    </template>
                  </div>
                </div>
              </div>
              <template x-if="invoiceModal.rows && invoiceModal.rows.length > 0">
                <div>
                  <div class="text-xs text-gray-400 font-semibold uppercase tracking-wide mb-1">Rader</div>
                  <div class="border border-gray-200 rounded-lg overflow-hidden divide-y divide-gray-100 text-sm">
                    <template x-for="(row, ri) in invoiceModal.rows" :key="ri">
                      <div class="px-3 py-2 flex justify-between gap-2">
                        <span class="text-gray-700" x-text="row.text || row.article || '–'"></span>
                        <span class="font-medium text-gray-900 shrink-0" x-text="fmtSEK(row.amount || row.unitPrice)"></span>
                      </div>
                    </template>
                  </div>
                </div>
              </template>
            </div>
          </template>
        </div>
      </div>
    </template>
  </div><!-- end analys tab -->

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- KPI + Tjänsteintäkter (always visible, below tabs)          -->
  <!-- ═══════════════════════════════════════════════════════════ -->

  <!-- KPI Table (editable) -->
  <div class="card" x-data="kpiEditor()">
    <div class="px-5 py-3 border-b border-gray-100 flex items-center justify-between">
      <h2 class="text-sm font-bold text-gray-900">KPI:er (tidrapporter)</h2>
      <span x-show="saveMsg" x-text="saveMsg" class="text-xs text-emerald-600 font-semibold" x-transition></span>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-right">
        <thead>
          <tr class="border-b border-gray-100">
            <th class="text-left sticky left-0 bg-white z-10 min-w-[180px]">Mått</th>
            <% for (let i = 0; i < 12; i++) { %>
              <th class="min-w-[70px]"><%= monthNames[i] %></th>
            <% } %>
            <th class="min-w-[80px] bg-gray-50 font-bold">Helår</th>
          </tr>
        </thead>
        <tbody class="text-[13px]">
          <%
            const editableKpiRows = [
              { key: 'rapporterade_h', label: 'Rapporterade h', bold: false },
              { key: 'interntid_h', label: 'Interntid h', bold: false },
              { key: 'franvaro_h', label: 'Frånvaro h', bold: false },
              { key: 'debiterade_h', label: 'Debiterade h', bold: true },
            ];
          %>
          <% for (const row of editableKpiRows) { %>
          <tr class="border-b border-gray-50 <%= row.bold ? 'font-semibold' : 'text-gray-600' %>">
            <td class="text-left sticky left-0 bg-white z-10"><%= row.label %></td>
            <% for (let i = 0; i < 12; i++) { %>
              <td class="num p-0">
                <input
                  type="text"
                  inputmode="decimal"
                  class="w-full text-right bg-transparent px-2 py-1.5 text-[13px] focus:bg-blue-50 focus:outline-none rounded <%= row.bold ? 'font-semibold' : '' %>"
                  :value="formatNum(data[<%= i %>]?.['<%= row.key %>'])"
                  @focus="$el.select()"
                  @blur="saveCell(<%= i %>, '<%= row.key %>', $el.value)"
                  @keydown.enter="$el.blur()"
                >
              </td>
            <% } %>
            <td class="num bg-gray-50 <%= row.bold ? 'font-bold' : '' %>" x-text="formatNum(totals['<%= row.key %>'])"></td>
          </tr>
          <% } %>
          <tr class="border-b border-gray-50 font-semibold bg-amber-50/30">
            <td class="text-left sticky left-0 bg-amber-50/30 z-10">Debiteringsgrad</td>
            <% for (let i = 0; i < 12; i++) { %>
              <td class="num" x-text="formatPct(data[<%= i %>]?.debiteringsgrad)"></td>
            <% } %>
            <td class="num bg-gray-50 font-bold" x-text="formatPct(totals.debiteringsgrad)"></td>
          </tr>
          <tr>
            <td class="text-left sticky left-0 bg-white z-10 font-semibold">Intäkt/h</td>
            <% for (let i = 0; i < 12; i++) { %>
              <td class="num" x-text="formatInt(data[<%= i %>]?.intakt_per_h)"></td>
            <% } %>
            <td class="num bg-gray-50 font-bold" x-text="formatInt(totals.intakt_per_h)"></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Service Revenue Table -->
  <div class="card">
    <div class="px-5 py-3 border-b border-gray-100">
      <h2 class="text-sm font-bold text-gray-900">Tjänsteintäkter (tkr)</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-right">
        <thead>
          <tr class="border-b border-gray-100">
            <th class="text-left sticky left-0 bg-white z-10 min-w-[180px]">Tjänst</th>
            <% for (let i = 0; i < 12; i++) { %>
              <th class="min-w-[70px]"><%= monthNames[i] %></th>
            <% } %>
            <th class="min-w-[80px] bg-gray-50 font-bold">Helår</th>
          </tr>
        </thead>
        <tbody class="text-[13px]">
          <%
            const srRows = [
              { key: 'tjanster',     label: 'Tjänster',           color: 'bg-violet-500' },
              { key: 'varor',        label: 'Varor',              color: 'bg-orange-500' },
              { key: 'dima',         label: 'DiMa',               color: 'bg-blue-500' },
              { key: 'supportavtal', label: 'Supportavtal',       color: 'bg-emerald-500' },
              { key: 'hemsidor',     label: 'Hemsidor',           color: 'bg-cyan-500' },
              { key: 'layout',       label: 'Layout/Foto/Film',   color: 'bg-pink-500' },
            ];
          %>
          <% for (let ri = 0; ri < srRows.length; ri++) { const sr = srRows[ri]; %>
          <tr class="<%= ri < srRows.length - 1 ? 'border-b border-gray-50' : '' %>">
            <td class="text-left sticky left-0 bg-white z-10">
              <span class="inline-flex items-center gap-1.5">
                <span class="w-2 h-2 rounded-full <%= sr.color %>"></span>
                <%= sr.label %>
              </span>
            </td>
            <% for (let i = 0; i < 12; i++) { %>
              <td class="num"><%= serviceRevenue[i] ? tkr(serviceRevenue[i][sr.key]) : '–' %></td>
            <% } %>
            <td class="num bg-gray-50 font-bold"><%= tkr(srTotal[sr.key]) %></td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script>
// Forecast chart
(function() {
  const monthNames = <%- JSON.stringify(monthNames) %>;
  const serviceRevenue = <%- JSON.stringify(serviceRevenue) %>;
  const forecastData = <%- JSON.stringify(forecastData) %>;

  const categories = [
    { key: 'dima',         label: 'DiMa',             color: [59, 130, 246] },
    { key: 'supportavtal', label: 'Supportavtal',       color: [16, 185, 129] },
    { key: 'hemsidor',     label: 'Hemsidor',           color: [6, 182, 212] },
    { key: 'tjanster',     label: 'Tjänster',           color: [139, 92, 246] },
    { key: 'layout',       label: 'Layout/Foto/Film',   color: [236, 72, 153] },
    { key: 'varor',        label: 'Varor',              color: [249, 115, 22] },
  ];

  const datasets = [];
  for (const cat of categories) {
    const [r, g, b] = cat.color;
    datasets.push({
      label: cat.label,
      data: monthNames.map((_, i) => serviceRevenue[i] ? Math.round((serviceRevenue[i][cat.key] || 0) / 1000) : 0),
      backgroundColor: `rgba(${r}, ${g}, ${b}, 0.85)`,
      stack: 'revenue',
      categoryPercentage: 0.6,
    });
    datasets.push({
      label: cat.label + ' (prognos)',
      data: monthNames.map((_, i) => forecastData[i] ? Math.round((forecastData[i][cat.key] || 0) / 1000) : 0),
      backgroundColor: `rgba(${r}, ${g}, ${b}, 0.3)`,
      borderColor: `rgba(${r}, ${g}, ${b}, 1)`,
      borderWidth: 1,
      stack: 'revenue',
      categoryPercentage: 0.6,
    });
  }

  const ctx = document.getElementById('forecastChart');
  new Chart(ctx, {
    type: 'bar',
    data: { labels: monthNames, datasets },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          labels: {
            filter: function(item) {
              return !item.text.includes('(prognos)');
            },
          },
        },
        tooltip: {
          callbacks: {
            label: function(ctx) {
              const label = ctx.dataset.label.replace(' (prognos)', '');
              const suffix = ctx.dataset.label.includes('(prognos)') ? ' (prognos)' : '';
              return label + suffix + ': ' + ctx.parsed.y + ' tkr';
            },
          },
        },
      },
      scales: {
        x: { stacked: true },
        y: { stacked: true, beginAtZero: true, ticks: { callback: v => v + ' tkr' } },
      },
    },
  });
})();

// Shared P&L editor for Budget and Prognos tabs
function plEditor(type) {
  const rawData = type === 'budget' ? <%- JSON.stringify(budget) %> : <%- JSON.stringify(prognos) %>;
  const year = <%= year %>;
  const emptyRow = { intakter: 0, ravaror: 0, ovriga_kostnader: 0, personalkostnad: 0, finansiella: 0 };

  return {
    data: rawData.map(d => d ? { ...emptyRow, ...d } : { ...emptyRow }),
    saveMsg: '',
    get totals() {
      const fields = ['intakter', 'ravaror', 'ovriga_kostnader', 'personalkostnad', 'finansiella'];
      const t = {};
      for (const f of fields) {
        t[f] = this.data.reduce((s, d) => s + (d[f] || 0), 0);
      }
      t.bruttovinst = t.intakter - t.ravaror;
      t.rorelseresultat = t.bruttovinst - t.ovriga_kostnader - t.personalkostnad;
      t.resultat = t.rorelseresultat + t.finansiella;
      return t;
    },
    rorelseresultat(i) {
      const d = this.data[i];
      return (d.intakter - d.ravaror) - d.ovriga_kostnader - d.personalkostnad;
    },
    resultat(i) {
      return this.rorelseresultat(i) + this.data[i].finansiella;
    },
    negCls(v) { return v < 0 ? 'text-red-600' : ''; },
    formatTkr(v) {
      if (!v) return '';
      return Math.round(v / 1000).toLocaleString('sv-SE');
    },
    formatPct(v) {
      if (!v || !isFinite(v)) return '–';
      return Math.round(v * 10) / 10 + '%';
    },
    parseTkr(str) {
      if (!str || str === '–') return 0;
      return (parseFloat(str.replace(/\s/g, '').replace(',', '.')) || 0) * 1000;
    },
    async saveCell(fyIndex, field, rawValue) {
      const value = this.parseTkr(rawValue);
      this.data[fyIndex][field] = value;
      const d = this.data[fyIndex];
      try {
        const r = await fetch('/api/ekonomi/' + type, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            year, fyIndex,
            intakter: d.intakter || 0,
            ravaror: d.ravaror || 0,
            ovriga_kostnader: d.ovriga_kostnader || 0,
            personalkostnad: d.personalkostnad || 0,
            finansiella: d.finansiella || 0,
          }),
        });
        const result = await r.json();
        if (result.success) {
          this.saveMsg = 'Sparat';
          setTimeout(() => this.saveMsg = '', 1500);
        }
      } catch (e) { console.error(type + ' save failed:', e); }
    },
  };
}

function analysisCards() {
  const pl = <%- JSON.stringify(plRows) %>;
  const budgetRows = <%- JSON.stringify(budgetRows) %>;
  const detail = <%- JSON.stringify(plDetail) %>;
  const monthLabels = <%- JSON.stringify(monthNames) %>;

  // Full month names for card headers (fiscal order: okt=0, nov=1, ..., sep=11)
  const fullMonthNames = ['Oktober', 'November', 'December', 'Januari', 'Februari', 'Mars', 'April', 'Maj', 'Juni', 'Juli', 'Augusti', 'September'];
  // Calendar years for each fiscal index (FY <%=year%>: okt-dec = <%=year-1%>, jan-sep = <%=year%>)
  const calYears = [<%= year-1 %>, <%= year-1 %>, <%= year-1 %>, <%= year %>, <%= year %>, <%= year %>, <%= year %>, <%= year %>, <%= year %>, <%= year %>, <%= year %>, <%= year %>];

  // Months with data, sorted newest first
  const monthsWithData = [];
  for (let i = 11; i >= 0; i--) {
    if (pl[i]) monthsWithData.push(i);
  }

  const defaultExpanded = monthsWithData.length > 0 ? monthsWithData[0] : -1;

  // P&L row definitions
  const plFields = [
    { key: 'intakter', label: 'Intäkter', sign: 1 },
    { key: 'ravaror', label: 'Råvaror', sign: -1 },
    { key: 'bruttovinst', label: 'Bruttovinst', computed: true, sep: true },
    { key: 'ovriga_kostnader', label: 'Övr. kostnader', sign: -1 },
    { key: 'personalkostnad', label: 'Personal', sign: -1 },
    { key: 'rorelseresultat', label: 'Rör.resultat', computed: true, sep: true },
    { key: 'finansiella', label: 'Finansiella', sign: -1 },
    { key: 'resultat', label: 'Resultat', computed: true, sep: true, highlight: true },
  ];

  function getVal(row, key) {
    if (!row) return 0;
    return row[key] || 0;
  }

  function fmtTkr(v) {
    if (v == null) return '–';
    return Math.round(v / 1000).toLocaleString('sv-SE');
  }

  function fmtDiff(v) {
    if (v == null) return '';
    const tkr = Math.round(v / 1000);
    return (tkr >= 0 ? '+' : '') + tkr.toLocaleString('sv-SE');
  }

  function fmtPct(curr, prev) {
    if (!prev || prev === 0) return '';
    const pct = Math.round(((curr - prev) / Math.abs(prev)) * 100);
    return '(' + (pct >= 0 ? '+' : '') + pct + '%)';
  }

  return {
    monthsWithData,
    expandedMonth: defaultExpanded,
    showAccounts: {},

    monthTitle(i) {
      return fullMonthNames[i] + ' ' + calYears[i];
    },

    isFirstMonth(i) { return i === 0; },

    // Get comparison source: previous month, or budget for first month in FY
    prevRow(i) {
      if (i === 0) return budgetRows[i];
      // Find previous month with data
      for (let j = i - 1; j >= 0; j--) {
        if (pl[j]) return pl[j];
      }
      return budgetRows[i];
    },

    compLabel(i) {
      if (i === 0) return 'vs budget';
      for (let j = i - 1; j >= 0; j--) {
        if (pl[j]) return 'vs ' + monthLabels[j];
      }
      return 'vs budget';
    },

    plFields,

    val(i, key) { return getVal(pl[i], key); },
    prev(i, key) { return getVal(this.prevRow(i), key); },
    diff(i, key) { return getVal(pl[i], key) - getVal(this.prevRow(i), key); },
    diffPct(i, key) { return fmtPct(getVal(pl[i], key), getVal(this.prevRow(i), key)); },

    isFlagged(i, key) {
      const d = this.diff(i, key);
      const prev = getVal(this.prevRow(i), key);
      const pct = prev !== 0 ? Math.abs((d / Math.abs(prev)) * 100) : 0;
      return Math.abs(d) > 50000 || pct > 20;
    },

    diffCls(i, key, field) {
      const d = this.diff(i, key);
      // For cost fields (sign=-1), negative diff (cost increase) is bad → red
      // For revenue/result fields, positive diff is good → green
      const isGood = field.sign === -1 ? d < 0 : d > 0;
      const isBad = field.sign === -1 ? d > 0 : d < 0;
      const flagged = this.isFlagged(i, key);
      let cls = '';
      if (flagged) cls += 'bg-amber-50 rounded px-1.5 py-0.5 ';
      if (isGood) cls += 'text-emerald-600';
      else if (isBad) cls += 'text-red-600';
      return cls;
    },

    // For computed rows (bruttovinst, resultat etc), positive diff = good
    resultDiffCls(i, key) {
      const d = this.diff(i, key);
      const flagged = this.isFlagged(i, key);
      let cls = '';
      if (flagged) cls += 'bg-amber-50 rounded px-1.5 py-0.5 ';
      if (d > 0) cls += 'text-emerald-600';
      else if (d < 0) cls += 'text-red-600';
      return cls;
    },

    resultatCls(i) {
      const r = getVal(pl[i], 'resultat');
      return r >= 0 ? 'text-emerald-600' : 'text-red-600';
    },

    fmtTkr(v) { return fmtTkr(v); },
    fmtDiff(v) { return fmtDiff(v); },
    fmtPct(i, key) { return this.diffPct(i, key); },

    // Account-level diffs
    accountDiffs(i) {
      const curr = detail[i];
      const prevIdx = i === 0 ? -1 : (() => { for (let j = i-1; j >= 0; j--) { if (detail[j]) return j; } return -1; })();
      const prev = prevIdx >= 0 ? detail[prevIdx] : null;

      if (!curr && !prev) return [];

      const groupDefs = [
        { key: 'intakter', label: 'Intäkter' },
        { key: 'ravaror', label: 'Råvaror' },
        { key: 'ovriga_kostnader', label: 'Övriga externa kostnader' },
        { key: 'personalkostnad', label: 'Personalkostnader' },
        { key: 'finansiella', label: 'Finansiella poster' },
      ];

      const result = [];
      for (const g of groupDefs) {
        const currAccts = (curr && curr[g.key]) || [];
        const prevAccts = (prev && prev[g.key]) || [];
        const accountMap = {};

        for (const a of currAccts) {
          if (!accountMap[a.account]) accountMap[a.account] = { account: a.account, name: a.name || '', vouchers: a.vouchers || [], curr: 0, prev: 0 };
          accountMap[a.account].curr += a.amount || 0;
          accountMap[a.account].vouchers = a.vouchers || accountMap[a.account].vouchers;
          if (!accountMap[a.account].name && a.name) accountMap[a.account].name = a.name;
        }
        for (const a of prevAccts) {
          if (!accountMap[a.account]) accountMap[a.account] = { account: a.account, name: a.name || '', vouchers: [], curr: 0, prev: 0 };
          accountMap[a.account].prev += a.amount || 0;
          if (!accountMap[a.account].name && a.name) accountMap[a.account].name = a.name;
        }

        const diffs = Object.values(accountMap)
          .map(a => ({ ...a, diff: a.curr - a.prev }))
          .filter(a => Math.abs(a.diff) > 100)
          .sort((a, b) => Math.abs(b.diff) - Math.abs(a.diff));

        if (diffs.length > 0) {
          result.push({ label: g.label, accounts: diffs });
        }
      }
      return result;
    },

    hasAccountDiffs(i) {
      return this.accountDiffs(i).length > 0;
    },

    acctDiffCls(diff) {
      return diff > 0 ? 'text-emerald-600' : diff < 0 ? 'text-red-600' : '';
    },

    toggleMonth(i) {
      this.expandedMonth = this.expandedMonth === i ? -1 : i;
    },
    toggleAccounts(i) {
      this.showAccounts[i] = !this.showAccounts[i];
    },

    // Voucher entry helpers (supports old string format + new {text, amount} format)
    vText(v) { return typeof v === 'string' ? v : (v?.text || ''); },
    vAmt(v) { return typeof v === 'object' ? (v?.amount || 0) : 0; },

    // Parse voucher text to detect if it's an invoice reference
    parseVoucherRef(text) {
      if (!text) return null;
      const m = text.match(/,\s*(\d+)\s*$/);
      if (!m) return null;
      const num = m[1];
      if (/kundfaktura/i.test(text)) return { number: num, type: 'customer' };
      if (/leverant.rsfaktura/i.test(text)) return { number: num, type: 'supplier' };
      return null;
    },

    voucherLink(text) {
      return this.parseVoucherRef(text) ? '#' : '';
    },

    invoiceModal: null,
    invoiceLoading: false,

    async openVoucher(text) {
      const ref = this.parseVoucherRef(text);
      if (!ref) return;
      this.invoiceLoading = true;
      this.invoiceModal = null;
      try {
        const r = await fetch(`/api/ekonomi/invoice-lookup?number=${ref.number}&type=${ref.type}`);
        const data = await r.json();
        if (data.success) {
          this.invoiceModal = data.invoice;
        } else {
          this.invoiceModal = { error: data.error || 'Kunde inte hämta fakturan' };
        }
      } catch (e) {
        this.invoiceModal = { error: e.message };
      }
      this.invoiceLoading = false;
    },

    closeModal() {
      this.invoiceModal = null;
    },

    fmtSEK(v) {
      if (!v) return '0 kr';
      return Math.round(v).toLocaleString('sv-SE') + ' kr';
    },

    fmtDate(d) {
      if (!d) return '–';
      return new Date(d).toLocaleDateString('sv-SE');
    },
  };
}

function kpiEditor() {
  const raw = <%- JSON.stringify(kpi) %>;
  const year = <%= year %>;
  return {
    data: raw.map(d => d ? { ...d } : { rapporterade_h: 0, interntid_h: 0, franvaro_h: 0, debiterade_h: 0, debiteringsgrad: 0, intakt_per_h: 0 }),
    saveMsg: '',
    get totals() {
      const fields = ['rapporterade_h', 'interntid_h', 'franvaro_h', 'debiterade_h'];
      const t = {};
      for (const f of fields) {
        t[f] = this.data.reduce((s, d) => s + (d?.[f] || 0), 0);
      }
      const tillganglig = t.rapporterade_h - t.franvaro_h;
      t.debiteringsgrad = tillganglig > 0 ? Math.round((t.debiterade_h / tillganglig) * 1000) / 10 : 0;
      t.intakt_per_h = t.debiterade_h > 0 ? Math.round(<%= plTotal.intakter || 0 %> / t.debiterade_h) : 0;
      return t;
    },
    formatNum(v) { return v ? v.toLocaleString('sv-SE', { minimumFractionDigits: 1, maximumFractionDigits: 1 }) : ''; },
    formatPct(v) { return v ? v.toFixed(1) + '%' : '–'; },
    formatInt(v) { return v ? Math.round(v).toLocaleString('sv-SE') : '–'; },
    parseNum(str) {
      if (!str || str === '–') return 0;
      return parseFloat(str.replace(/\s/g, '').replace(',', '.')) || 0;
    },
    async saveCell(fyIndex, field, rawValue) {
      const value = this.parseNum(rawValue);
      if (!this.data[fyIndex]) {
        this.data[fyIndex] = { rapporterade_h: 0, interntid_h: 0, franvaro_h: 0, debiterade_h: 0, debiteringsgrad: 0, intakt_per_h: 0 };
      }
      this.data[fyIndex][field] = value;
      const d = this.data[fyIndex];
      try {
        const r = await fetch('/api/ekonomi/kpi', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            year, fyIndex,
            rapporterade_h: d.rapporterade_h || 0,
            interntid_h: d.interntid_h || 0,
            franvaro_h: d.franvaro_h || 0,
            debiterade_h: d.debiterade_h || 0,
          }),
        });
        const result = await r.json();
        if (result.success) {
          this.data[fyIndex].debiteringsgrad = result.debiteringsgrad;
          this.data[fyIndex].intakt_per_h = result.intakt_per_h;
          this.saveMsg = 'Sparat';
          setTimeout(() => this.saveMsg = '', 1500);
        }
      } catch (e) { console.error('KPI save failed:', e); }
    },
  };
}
</script>
