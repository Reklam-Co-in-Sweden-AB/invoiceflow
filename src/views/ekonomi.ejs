<%
  function tkr(v) {
    if (v == null) return '–';
    const val = Math.round(v / 1000);
    return val.toLocaleString('sv-SE');
  }
  function neg(v) {
    return v != null && v < 0 ? 'text-red-600' : '';
  }
  function pct(v) {
    if (v == null) return '–';
    return v.toFixed(1) + '%';
  }
  function num1(v) {
    if (v == null) return '–';
    return v.toLocaleString('sv-SE', { minimumFractionDigits: 1, maximumFractionDigits: 1 });
  }
  function numInt(v) {
    if (v == null) return '–';
    return Math.round(v).toLocaleString('sv-SE');
  }
%>

<div class="p-6 space-y-6 animate-fade-up" x-data="{ syncing: false, syncStatus: '' }">

  <!-- Header: Year navigation + Sync -->
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-4">
      <h1 class="text-xl font-bold text-gray-900">Ekonomi</h1>
      <div class="flex items-center gap-1 text-sm">
        <a href="/ekonomi?year=<%= year - 1 %>" class="px-2 py-1 rounded hover:bg-gray-100 text-gray-500">&larr; <%= year - 2 %>/<%= String(year - 1).slice(2) %></a>
        <span class="px-3 py-1 font-bold text-gray-900 bg-gray-100 rounded"><%= yearLabel %></span>
        <a href="/ekonomi?year=<%= year + 1 %>" class="px-2 py-1 rounded hover:bg-gray-100 text-gray-500"><%= year %>/<%= String(year + 1).slice(2) %> &rarr;</a>
      </div>
    </div>
    <div class="flex items-center gap-3">
      <% if (latestSync) { %>
        <span class="text-xs text-gray-400">Synkad: <%= new Date(latestSync).toLocaleString('sv-SE') %></span>
      <% } %>
      <span x-show="syncing" class="text-xs text-blue-600 font-semibold" x-text="syncStatus"></span>
      <button
        class="btn btn-accent"
        :class="{ 'opacity-50 pointer-events-none': syncing }"
        @click="
          syncing = true;
          const year = <%= year %>;
          const monthNames = ['okt','nov','dec','jan','feb','mar','apr','maj','jun','jul','aug','sep'];
          const steps = [
            { type: 'pl', label: 'Resultatrapport' },
            { type: 'service_revenue', label: 'Tjänsteintäkter' },
            { type: 'kpi', label: 'KPI:er' },
          ];
          (async () => {
            syncStatus = 'Rensar gammal data...';
            try {
              await fetch('/api/sync/ekonomi/cleanup?year=' + year, { method: 'POST' });
            } catch (e) { /* ignore cleanup errors */ }
            for (const step of steps) {
              for (let m = 0; m < 12; m++) {
                syncStatus = step.label + ' — ' + monthNames[m] + '...';
                try {
                  const r = await fetch('/api/sync/ekonomi?year=' + year + '&type=' + step.type + '&month=' + m, { method: 'POST' });
                  const data = await r.json();
                  if (data.success === false) { alert('Fel vid ' + step.label + ' ' + monthNames[m] + ': ' + (data.error || '')); syncing = false; return; }
                } catch (e) { alert('Nätverksfel vid ' + step.label + ' ' + monthNames[m] + ': ' + e.message); syncing = false; return; }
              }
            }
            window.location.reload();
          })();
        "
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
        </svg>
        <span x-text="syncing ? 'Synkar...' : 'Synka'"></span>
      </button>
    </div>
  </div>

  <!-- Stat cards -->
  <div class="grid grid-cols-4 gap-4">
    <div class="card stat-card blue p-4">
      <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Intäkter YTD</div>
      <div class="text-2xl font-bold text-gray-900 mt-1 num"><%= tkr(intakterYtd) %> <span class="text-sm font-normal text-gray-400">tkr</span></div>
    </div>
    <div class="card stat-card green p-4">
      <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Resultat YTD</div>
      <div class="text-2xl font-bold mt-1 num <%= neg(resultatYtd) %>"><%= tkr(resultatYtd) %> <span class="text-sm font-normal text-gray-400">tkr</span></div>
    </div>
    <div class="card stat-card amber p-4">
      <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Debiteringsgrad</div>
      <div class="text-2xl font-bold text-gray-900 mt-1 num"><%= pct(latestDebiteringsgrad) %></div>
    </div>
    <div class="card stat-card purple p-4">
      <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Kassa & bank</div>
      <div class="text-2xl font-bold mt-1 num <%= neg(latestKassaBank) %>"><%= tkr(latestKassaBank) %> <span class="text-sm font-normal text-gray-400">tkr</span></div>
    </div>
  </div>

  <!-- P&L Table -->
  <div class="card">
    <div class="px-5 py-3 border-b border-gray-100">
      <h2 class="text-sm font-bold text-gray-900">Resultatrapport (tkr)</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-right">
        <thead>
          <tr class="border-b border-gray-100">
            <th class="text-left sticky left-0 bg-white z-10 min-w-[180px]">Post</th>
            <% for (let i = 0; i < 12; i++) { %>
              <th class="min-w-[70px]"><%= monthNames[i] %></th>
            <% } %>
            <th class="min-w-[80px] bg-gray-50 font-bold">Helår</th>
          </tr>
        </thead>
        <tbody class="text-[13px]">
          <!-- Intäkter -->
          <tr class="border-b border-gray-50 font-semibold">
            <td class="text-left sticky left-0 bg-white z-10">Intäkter</td>
            <% for (let i = 0; i < 12; i++) { %>
              <td class="num <%= neg(plRows[i]?.intakter) %>"><%= plRows[i] ? tkr(plRows[i].intakter) : '–' %></td>
            <% } %>
            <td class="num bg-gray-50 font-bold <%= neg(plTotal.intakter) %>"><%= tkr(plTotal.intakter) %></td>
          </tr>
          <!-- Råvaror -->
          <tr class="border-b border-gray-50 text-gray-600">
            <td class="text-left sticky left-0 bg-white z-10">Råvaror</td>
            <% for (let i = 0; i < 12; i++) { %>
              <td class="num <%= neg(plRows[i]?.ravaror) %>"><%= plRows[i] ? tkr(plRows[i].ravaror) : '–' %></td>
            <% } %>
            <td class="num bg-gray-50 <%= neg(plTotal.ravaror) %>"><%= tkr(plTotal.ravaror) %></td>
          </tr>
          <!-- Bruttovinst -->
          <tr class="border-b border-gray-200 font-semibold bg-blue-50/30">
            <td class="text-left sticky left-0 bg-blue-50/30 z-10">Bruttovinst</td>
            <% for (let i = 0; i < 12; i++) { %>
              <td class="num <%= neg(plRows[i]?.bruttovinst) %>"><%= plRows[i] ? tkr(plRows[i].bruttovinst) : '–' %></td>
            <% } %>
            <td class="num bg-gray-50 font-bold <%= neg(plTotal.bruttovinst) %>"><%= tkr(plTotal.bruttovinst) %></td>
          </tr>
          <!-- Övriga kostnader -->
          <tr class="border-b border-gray-50 text-gray-600">
            <td class="text-left sticky left-0 bg-white z-10">Övriga externa kostnader</td>
            <% for (let i = 0; i < 12; i++) { %>
              <td class="num <%= neg(plRows[i]?.ovriga_kostnader) %>"><%= plRows[i] ? tkr(plRows[i].ovriga_kostnader) : '–' %></td>
            <% } %>
            <td class="num bg-gray-50 <%= neg(plTotal.ovriga_kostnader) %>"><%= tkr(plTotal.ovriga_kostnader) %></td>
          </tr>
          <tr class="border-b border-gray-50 text-gray-400 text-[11px]">
            <td class="text-left sticky left-0 bg-white z-10 pl-6">% av intäkter</td>
            <% for (let i = 0; i < 12; i++) { %>
              <td class="num"><%= plRows[i] ? pct(plRows[i].ovriga_pct) : '–' %></td>
            <% } %>
            <td class="num bg-gray-50"><%= pct(plTotal.ovriga_pct) %></td>
          </tr>
          <!-- Personalkostnad -->
          <tr class="border-b border-gray-50 text-gray-600">
            <td class="text-left sticky left-0 bg-white z-10">Personalkostnader</td>
            <% for (let i = 0; i < 12; i++) { %>
              <td class="num <%= neg(plRows[i]?.personalkostnad) %>"><%= plRows[i] ? tkr(plRows[i].personalkostnad) : '–' %></td>
            <% } %>
            <td class="num bg-gray-50 <%= neg(plTotal.personalkostnad) %>"><%= tkr(plTotal.personalkostnad) %></td>
          </tr>
          <tr class="border-b border-gray-50 text-gray-400 text-[11px]">
            <td class="text-left sticky left-0 bg-white z-10 pl-6">% av intäkter</td>
            <% for (let i = 0; i < 12; i++) { %>
              <td class="num"><%= plRows[i] ? pct(plRows[i].personal_pct) : '–' %></td>
            <% } %>
            <td class="num bg-gray-50"><%= pct(plTotal.personal_pct) %></td>
          </tr>
          <!-- Övriga rörelsekostnader (only show if any month has data) -->
          <% if (plRows.some(d => d && d.ovriga_rorelsekostnader)) { %>
          <tr class="border-b border-gray-50 text-gray-600">
            <td class="text-left sticky left-0 bg-white z-10">Övriga rörelsekostnader</td>
            <% for (let i = 0; i < 12; i++) { %>
              <td class="num"><%= plRows[i] ? tkr(plRows[i].ovriga_rorelsekostnader || 0) : '–' %></td>
            <% } %>
            <td class="num bg-gray-50"><%= tkr(plTotal.ovriga_rorelsekostnader) %></td>
          </tr>
          <% } %>
          <!-- Rörelseresultat -->
          <tr class="border-b border-gray-200 font-semibold bg-green-50/30">
            <td class="text-left sticky left-0 bg-green-50/30 z-10">Rörelseresultat</td>
            <% for (let i = 0; i < 12; i++) { %>
              <td class="num <%= neg(plRows[i]?.rorelseresultat) %>"><%= plRows[i] ? tkr(plRows[i].rorelseresultat) : '–' %></td>
            <% } %>
            <td class="num bg-gray-50 font-bold <%= neg(plTotal.rorelseresultat) %>"><%= tkr(plTotal.rorelseresultat) %></td>
          </tr>
          <tr class="border-b border-gray-50 text-gray-400 text-[11px]">
            <td class="text-left sticky left-0 bg-white z-10 pl-6">% av intäkter</td>
            <% for (let i = 0; i < 12; i++) { %>
              <td class="num"><%= plRows[i] ? pct(plRows[i].rorelseresultat_pct) : '–' %></td>
            <% } %>
            <td class="num bg-gray-50"><%= pct(plTotal.rorelseresultat_pct) %></td>
          </tr>
          <!-- Finansiella poster -->
          <tr class="border-b border-gray-50 text-gray-600">
            <td class="text-left sticky left-0 bg-white z-10">Finansiella poster</td>
            <% for (let i = 0; i < 12; i++) { %>
              <td class="num <%= neg(plRows[i]?.finansiella) %>"><%= plRows[i] ? tkr(plRows[i].finansiella || 0) : '–' %></td>
            <% } %>
            <td class="num bg-gray-50 <%= neg(plTotal.finansiella) %>"><%= tkr(plTotal.finansiella) %></td>
          </tr>
          <!-- Skatt (only show if any month has data) -->
          <% if (plRows.some(d => d && d.skatt)) { %>
          <tr class="border-b border-gray-50 text-gray-600">
            <td class="text-left sticky left-0 bg-white z-10">Skatt</td>
            <% for (let i = 0; i < 12; i++) { %>
              <td class="num <%= neg(plRows[i]?.skatt) %>"><%= plRows[i] ? tkr(plRows[i].skatt || 0) : '–' %></td>
            <% } %>
            <td class="num bg-gray-50 <%= neg(plTotal.skatt) %>"><%= tkr(plTotal.skatt) %></td>
          </tr>
          <% } %>
          <!-- Resultat -->
          <tr class="border-b border-gray-200 font-bold bg-amber-50/30">
            <td class="text-left sticky left-0 bg-amber-50/30 z-10">Resultat</td>
            <% for (let i = 0; i < 12; i++) { %>
              <td class="num <%= neg(plRows[i]?.resultat) %>"><%= plRows[i] ? tkr(plRows[i].resultat) : '–' %></td>
            <% } %>
            <td class="num bg-gray-50 font-bold <%= neg(plTotal.resultat) %>"><%= tkr(plTotal.resultat) %></td>
          </tr>
          <tr class="border-b border-gray-50 text-gray-400 text-[11px]">
            <td class="text-left sticky left-0 bg-white z-10 pl-6">% av intäkter</td>
            <% for (let i = 0; i < 12; i++) { %>
              <td class="num"><%= plRows[i] ? pct(plRows[i].resultat_pct) : '–' %></td>
            <% } %>
            <td class="num bg-gray-50"><%= pct(plTotal.resultat_pct) %></td>
          </tr>
          <!-- Ack Resultat -->
          <tr class="border-b border-gray-50 text-gray-500">
            <td class="text-left sticky left-0 bg-white z-10">Ack resultat</td>
            <% for (let i = 0; i < 12; i++) { %>
              <td class="num <%= neg(ackResultatArr[i]) %>"><%= tkr(ackResultatArr[i]) %></td>
            <% } %>
            <td class="num bg-gray-50"></td>
          </tr>
          <!-- Kassa & bank -->
          <tr class="text-gray-600">
            <td class="text-left sticky left-0 bg-white z-10 font-semibold">Kassa & bank</td>
            <% for (let i = 0; i < 12; i++) { %>
              <td class="num <%= neg(plRows[i]?.kassa_bank) %>"><%= plRows[i] ? tkr(plRows[i].kassa_bank) : '–' %></td>
            <% } %>
            <td class="num bg-gray-50 font-bold <%= neg(plTotal.kassa_bank) %>"><%= tkr(plTotal.kassa_bank) %></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Budget Table (editable) -->
  <div class="card" x-data="budgetEditor()">
    <div class="px-5 py-3 border-b border-gray-100 flex items-center justify-between">
      <h2 class="text-sm font-bold text-gray-900">Budget (tkr)</h2>
      <span x-show="saveMsg" x-text="saveMsg" class="text-xs text-emerald-600 font-semibold" x-transition></span>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-right">
        <thead>
          <tr class="border-b border-gray-100">
            <th class="text-left sticky left-0 bg-white z-10 min-w-[180px]">Post</th>
            <% for (let i = 0; i < 12; i++) { %>
              <th class="min-w-[70px]"><%= monthNames[i] %></th>
            <% } %>
            <th class="min-w-[80px] bg-gray-50 font-bold">Helår</th>
          </tr>
        </thead>
        <tbody class="text-[13px]">
          <tr class="border-b border-gray-50 font-semibold bg-purple-50/30">
            <td class="text-left sticky left-0 bg-purple-50/30 z-10">Budget intäkter</td>
            <% for (let i = 0; i < 12; i++) { %>
              <td class="num p-0">
                <input
                  type="text"
                  inputmode="decimal"
                  class="w-full text-right bg-transparent px-2 py-1.5 text-[13px] font-semibold focus:bg-purple-50 focus:outline-none rounded"
                  :value="formatTkr(data[<%= i %>]?.intakter)"
                  @focus="$el.select()"
                  @blur="saveCell(<%= i %>, $el.value)"
                  @keydown.enter="$el.blur()"
                >
              </td>
            <% } %>
            <td class="num bg-gray-50 font-bold" x-text="formatTkr(totals.intakter)"></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- KPI Table (editable) -->
  <div class="card" x-data="kpiEditor()">
    <div class="px-5 py-3 border-b border-gray-100 flex items-center justify-between">
      <h2 class="text-sm font-bold text-gray-900">KPI:er (tidrapporter)</h2>
      <span x-show="saveMsg" x-text="saveMsg" class="text-xs text-emerald-600 font-semibold" x-transition></span>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-right">
        <thead>
          <tr class="border-b border-gray-100">
            <th class="text-left sticky left-0 bg-white z-10 min-w-[180px]">Mått</th>
            <% for (let i = 0; i < 12; i++) { %>
              <th class="min-w-[70px]"><%= monthNames[i] %></th>
            <% } %>
            <th class="min-w-[80px] bg-gray-50 font-bold">Helår</th>
          </tr>
        </thead>
        <tbody class="text-[13px]">
          <%
            const editableKpiRows = [
              { key: 'rapporterade_h', label: 'Rapporterade h', bold: false },
              { key: 'interntid_h', label: 'Interntid h', bold: false },
              { key: 'franvaro_h', label: 'Frånvaro h', bold: false },
              { key: 'debiterade_h', label: 'Debiterade h', bold: true },
            ];
          %>
          <% for (const row of editableKpiRows) { %>
          <tr class="border-b border-gray-50 <%= row.bold ? 'font-semibold' : 'text-gray-600' %>">
            <td class="text-left sticky left-0 bg-white z-10"><%= row.label %></td>
            <% for (let i = 0; i < 12; i++) { %>
              <td class="num p-0">
                <input
                  type="text"
                  inputmode="decimal"
                  class="w-full text-right bg-transparent px-2 py-1.5 text-[13px] focus:bg-blue-50 focus:outline-none rounded <%= row.bold ? 'font-semibold' : '' %>"
                  :value="formatNum(data[<%= i %>]?.['<%= row.key %>'])"
                  @focus="$el.select()"
                  @blur="saveCell(<%= i %>, '<%= row.key %>', $el.value)"
                  @keydown.enter="$el.blur()"
                >
              </td>
            <% } %>
            <td class="num bg-gray-50 <%= row.bold ? 'font-bold' : '' %>" x-text="formatNum(totals['<%= row.key %>'])"></td>
          </tr>
          <% } %>
          <!-- Debiteringsgrad (computed) -->
          <tr class="border-b border-gray-50 font-semibold bg-amber-50/30">
            <td class="text-left sticky left-0 bg-amber-50/30 z-10">Debiteringsgrad</td>
            <% for (let i = 0; i < 12; i++) { %>
              <td class="num" x-text="formatPct(data[<%= i %>]?.debiteringsgrad)"></td>
            <% } %>
            <td class="num bg-gray-50 font-bold" x-text="formatPct(totals.debiteringsgrad)"></td>
          </tr>
          <!-- Intäkt/h (computed) -->
          <tr>
            <td class="text-left sticky left-0 bg-white z-10 font-semibold">Intäkt/h</td>
            <% for (let i = 0; i < 12; i++) { %>
              <td class="num" x-text="formatInt(data[<%= i %>]?.intakt_per_h)"></td>
            <% } %>
            <td class="num bg-gray-50 font-bold" x-text="formatInt(totals.intakt_per_h)"></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Service Revenue Table -->
  <div class="card">
    <div class="px-5 py-3 border-b border-gray-100">
      <h2 class="text-sm font-bold text-gray-900">Tjänsteintäkter (tkr)</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-right">
        <thead>
          <tr class="border-b border-gray-100">
            <th class="text-left sticky left-0 bg-white z-10 min-w-[180px]">Tjänst</th>
            <% for (let i = 0; i < 12; i++) { %>
              <th class="min-w-[70px]"><%= monthNames[i] %></th>
            <% } %>
            <th class="min-w-[80px] bg-gray-50 font-bold">Helår</th>
          </tr>
        </thead>
        <tbody class="text-[13px]">
          <%
            const srRows = [
              { key: 'tjanster',     label: 'Tjänster',           color: 'bg-violet-500' },
              { key: 'varor',        label: 'Varor',              color: 'bg-orange-500' },
              { key: 'dima',         label: 'DiMa',               color: 'bg-blue-500' },
              { key: 'supportavtal', label: 'Supportavtal',       color: 'bg-emerald-500' },
              { key: 'hemsidor',     label: 'Hemsidor',           color: 'bg-cyan-500' },
              { key: 'layout',       label: 'Layout/Foto/Film',   color: 'bg-pink-500' },
            ];
          %>
          <% for (let ri = 0; ri < srRows.length; ri++) { const sr = srRows[ri]; %>
          <tr class="<%= ri < srRows.length - 1 ? 'border-b border-gray-50' : '' %>">
            <td class="text-left sticky left-0 bg-white z-10">
              <span class="inline-flex items-center gap-1.5">
                <span class="w-2 h-2 rounded-full <%= sr.color %>"></span>
                <%= sr.label %>
              </span>
            </td>
            <% for (let i = 0; i < 12; i++) { %>
              <td class="num"><%= serviceRevenue[i] ? tkr(serviceRevenue[i][sr.key]) : '–' %></td>
            <% } %>
            <td class="num bg-gray-50 font-bold"><%= tkr(srTotal[sr.key]) %></td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

</div>

<script>
function budgetEditor() {
  const raw = <%- JSON.stringify(budget) %>;
  const year = <%= year %>;
  return {
    data: raw.map(d => d ? { ...d } : { intakter: 0 }),
    saveMsg: '',
    get totals() {
      return {
        intakter: this.data.reduce((s, d) => s + (d?.intakter || 0), 0),
      };
    },
    formatTkr(v) {
      if (!v) return '';
      return Math.round(v / 1000).toLocaleString('sv-SE');
    },
    parseTkr(str) {
      if (!str || str === '–') return 0;
      return (parseFloat(str.replace(/\s/g, '').replace(',', '.')) || 0) * 1000;
    },
    async saveCell(fyIndex, rawValue) {
      const intakter = this.parseTkr(rawValue);
      this.data[fyIndex] = { intakter };
      try {
        const r = await fetch('/api/ekonomi/budget', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ year, fyIndex, intakter }),
        });
        const result = await r.json();
        if (result.success) {
          this.saveMsg = 'Sparat';
          setTimeout(() => this.saveMsg = '', 1500);
        }
      } catch (e) { console.error('Budget save failed:', e); }
    },
  };
}

function kpiEditor() {
  const raw = <%- JSON.stringify(kpi) %>;
  const year = <%= year %>;
  return {
    data: raw.map(d => d ? { ...d } : { rapporterade_h: 0, interntid_h: 0, franvaro_h: 0, debiterade_h: 0, debiteringsgrad: 0, intakt_per_h: 0 }),
    saveMsg: '',
    get totals() {
      const fields = ['rapporterade_h', 'interntid_h', 'franvaro_h', 'debiterade_h'];
      const t = {};
      for (const f of fields) {
        t[f] = this.data.reduce((s, d) => s + (d?.[f] || 0), 0);
      }
      const tillganglig = t.rapporterade_h - t.franvaro_h;
      t.debiteringsgrad = tillganglig > 0 ? Math.round((t.debiterade_h / tillganglig) * 1000) / 10 : 0;
      t.intakt_per_h = t.debiterade_h > 0 ? Math.round(<%= plTotal.intakter || 0 %> / t.debiterade_h) : 0;
      return t;
    },
    formatNum(v) { return v ? v.toLocaleString('sv-SE', { minimumFractionDigits: 1, maximumFractionDigits: 1 }) : ''; },
    formatPct(v) { return v ? v.toFixed(1) + '%' : '–'; },
    formatInt(v) { return v ? Math.round(v).toLocaleString('sv-SE') : '–'; },
    parseNum(str) {
      if (!str || str === '–') return 0;
      return parseFloat(str.replace(/\s/g, '').replace(',', '.')) || 0;
    },
    async saveCell(fyIndex, field, rawValue) {
      const value = this.parseNum(rawValue);
      if (!this.data[fyIndex]) {
        this.data[fyIndex] = { rapporterade_h: 0, interntid_h: 0, franvaro_h: 0, debiterade_h: 0, debiteringsgrad: 0, intakt_per_h: 0 };
      }
      this.data[fyIndex][field] = value;
      const d = this.data[fyIndex];
      try {
        const r = await fetch('/api/ekonomi/kpi', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            year, fyIndex,
            rapporterade_h: d.rapporterade_h || 0,
            interntid_h: d.interntid_h || 0,
            franvaro_h: d.franvaro_h || 0,
            debiterade_h: d.debiterade_h || 0,
          }),
        });
        const result = await r.json();
        if (result.success) {
          this.data[fyIndex].debiteringsgrad = result.debiteringsgrad;
          this.data[fyIndex].intakt_per_h = result.intakt_per_h;
          this.saveMsg = 'Sparat';
          setTimeout(() => this.saveMsg = '', 1500);
        }
      } catch (e) { console.error('KPI save failed:', e); }
    },
  };
}
</script>
