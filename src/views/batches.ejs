<%
function formatSEK(n) { return Math.round(n).toLocaleString('sv-SE') + ' kr'; }
const MONTHS_SV = ['Januari','Februari','Mars','April','Maj','Juni','Juli','Augusti','September','Oktober','November','December'];
const monthName = MONTHS_SV[currentMonth.getMonth()] + ' ' + currentMonth.getFullYear();

const batchColors = [
  'from-emerald-500 to-emerald-400',
  'from-blue-500 to-blue-400',
  'from-amber-500 to-amber-400',
  'from-gray-500 to-gray-400',
];
const statusLabels = { pending: 'Väntar', exporting: 'Exporterar', exported: 'Exporterad', confirmed: 'Bekräftad' };
%>

<div class="p-7 space-y-5">
  <div class="flex items-center justify-between">
    <div>
      <h2 class="text-lg font-bold text-gray-900">Batcher</h2>
      <p class="text-xs text-gray-400 mt-0.5"><%= monthName %> &middot; LPT-fördelning över 4 veckor</p>
    </div>
    <div class="flex gap-2">
      <form method="POST" action="/batches/distribute">
        <input type="hidden" name="month" value="<%= currentMonth.toISOString().slice(0,7) %>">
        <button type="submit" class="btn btn-ghost text-xs">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
          Omfördela
        </button>
      </form>
    </div>
  </div>

  <% if (batches.length > 0) { %>
    <!-- Chart -->
    <div class="card p-5">
      <h3 class="text-sm font-semibold text-gray-900 mb-1">Monetär fördelning</h3>
      <div class="h-44"><canvas id="batchChart"></canvas></div>
    </div>

    <!-- Batch cards -->
    <div class="grid grid-cols-4 gap-4">
      <% batches.forEach((batch, i) => { %>
        <div class="card overflow-hidden">
          <div class="bg-gradient-to-r <%= batchColors[i] || batchColors[3] %> px-4 py-3 flex items-center justify-between">
            <div>
              <div class="font-bold text-white text-sm">Vecka <%= batch.weekNumber %></div>
              <div class="text-xs text-white/70">
                <% const d = new Date(batch.scheduledDate); %>
                Mån <%= d.getDate() %> <%= MONTHS_SV[d.getMonth()].toLowerCase().slice(0,3) %>
              </div>
            </div>
            <span class="pill text-xs" style="background:rgba(255,255,255,0.2);color:white;border:0"><%= statusLabels[batch.status] || batch.status %></span>
          </div>
          <div class="p-4">
            <div class="text-xl font-extrabold text-gray-900 num"><%= formatSEK(batch.totalAmount) %></div>
            <div class="text-xs text-gray-400 mb-3"><%= batch.invoiceCount %> fakturor</div>
          </div>
        </div>
      <% }) %>
    </div>

    <% const totalBatch = batches.reduce((s,b) => s + b.totalAmount, 0); %>
    <% const ideal = totalBatch / 4; %>
    <% const maxDev = Math.max(...batches.map(b => Math.abs(b.totalAmount - ideal))); %>
    <% const devPct = ideal > 0 ? ((maxDev / ideal) * 100).toFixed(1) : 0; %>
    <div class="bg-emerald-50 border border-emerald-200/60 rounded-xl px-5 py-3.5 flex items-center gap-3">
      <div class="w-7 h-7 rounded-full bg-emerald-100 flex items-center justify-center">
        <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      </div>
      <div>
        <div class="text-xs font-semibold text-emerald-800">Jämn fördelning uppnådd</div>
        <div class="text-xs text-emerald-600">Max avvikelse: <%= devPct %>% (<%= formatSEK(maxDev) %>) från ideal <%= formatSEK(ideal) %>/vecka</div>
      </div>
    </div>
  <% } else { %>
    <div class="card p-8 text-center">
      <p class="text-gray-400 mb-4">Inga batcher ännu. Godkänn fakturor och kör fördelning.</p>
      <form method="POST" action="/batches/distribute">
        <input type="hidden" name="month" value="<%= currentMonth.toISOString().slice(0,7) %>">
        <button type="submit" class="btn btn-accent">Kör fördelning</button>
      </form>
    </div>
  <% } %>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', () => {
  const ctx = document.getElementById('batchChart');
  if (!ctx) return;
  const data = <%- JSON.stringify(batches.map(b => ({ label: 'V.' + b.weekNumber, amount: b.totalAmount }))) %>;
  new Chart(ctx, {
    type: 'bar',
    data: {
      labels: data.map(d => d.label),
      datasets: [{
        data: data.map(d => d.amount),
        backgroundColor: ['#10b981','#3366ff','#f59e0b','#6b7280'],
        borderRadius: 6,
        barThickness: 48,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        y: { beginAtZero: true, ticks: { callback: v => (v/1000)+'k' } },
        x: { grid: { display: false } }
      }
    }
  });
});
</script>
