# Supabase PostgreSQL (connection pooler — Transaction mode)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Supabase PostgreSQL (direct connection — for migrations)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-north-1.pooler.supabase.com:5432/postgres"

SESSION_SECRET="change-me-to-random-string"
PORT=3000

# Blikk API
BLIKK_API_URL=https://publicapi.blikk.com
BLIKK_USERNAME=
BLIKK_PASSWORD=

# Visma eEkonomi
VISMA_CLIENT_ID=
VISMA_CLIENT_SECRET=
VISMA_REDIRECT_URI=http://localhost:3000/settings/visma/callback
VISMA_API_URL=https://eaccountingapi.vismaonline.com
